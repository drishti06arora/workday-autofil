{
  "manifest_version": 3,
  "name": "Workday Autofill",
  "description": "A Chrome extension to autofill Workday forms.",
  "version": "1.0.0",
  "host_permissions": [
    "*://*.myworkdayjobs.com/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Workday Autofill"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.myworkdayjobs.com/*"
      ],
      "js": [
        "extraction.js",
        "agent-client.js",
        "ui.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
